# BKNS Wiki — Environment Configuration Template
# Copy to .env and fill in real values. NEVER commit .env to git.

# ─── Telegram Bot (REQUIRED) ────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
ADMIN_TELEGRAM_ID=123456789

# ─── Google Cloud / Vertex AI (REQUIRED) ────────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# ─── Gemini Models (optional — defaults shown) ──────────────────────────
MODEL_FLASH=gemini-2.5-flash
MODEL_PRO=gemini-2.5-pro
MODEL_PRO_NEW=gemini-3.1-pro-preview
MODEL_PRO_NEW_LOCATION=global
USE_PRO_NEW=false

# ─── OpenAI / Dual-Vote (optional — only if DUAL_VOTE_ENABLED=true) ─────
# Key prefix determines routing:
#   sk-proj-*  → https://api.openai.com/v1
#   sk-or-v1-* → https://openrouter.ai/api/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
OPENAI_BASE_URL=https://api.openai.com/v1
DUAL_VOTE_ENABLED=false

# ─── Cost Guardrails (optional) ─────────────────────────────────────────
MAX_QUERY_COST_USD=0.01
MONTHLY_BUDGET_USD=50

# ─── Workspace (optional) ───────────────────────────────────────────────
WIKI_WORKSPACE=/wiki
